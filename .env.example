# ==============================================================================
# PLANTILLA DE CONFIGURACIÓN (.env.example)
# ==============================================================================
# Instrucciones:
# 1. Copia este archivo y cámbiale el nombre a ".env" (sin el .example).
# 2. Rellena los espacios vacíos con tus propias credenciales
# ==============================================================================

# Credencial para la API de OpenAI (necesaria para el razonamiento del LLM)
OPENAI_API_KEY=

# Credenciales específicas para las herramientas del Agente Cencosud
GITHUB_TOKEN=
GITHUB_BASE_URL=

